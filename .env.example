# Turso (libSQL) — get from: turso db show job-hunter --url
TURSO_DATABASE_URL=libsql://your-db.turso.io
# Get with: turso db tokens create job-hunter --expiration none
TURSO_AUTH_TOKEN_FULL=eyJ...
# Get with: turso db tokens create job-hunter --read-only --expiration none
TURSO_AUTH_TOKEN_READ=eyJ...

# Anthropic API (used for the one-shot resume extraction at upload, and as a fallback
# if routine Max usage gets rate-limited)
ANTHROPIC_API_KEY=sk-ant-...

# Google Drive (service account JSON path; setup in Stage H)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/drive-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# Routine trigger endpoint (filled in once routines are deployed via /schedule)
ANTHROPIC_API_TRIGGER_URL=
ANTHROPIC_API_TRIGGER_TOKEN=

# Apify API token — get from https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...
